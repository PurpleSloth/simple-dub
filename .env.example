# Ключ OpenRouter вводится в настройках установленного приложения
# и хранится в Windows Credential Manager.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TRANSLATION_MODEL=google/gemini-3.5-flash-lite

# Локальные модели и инструменты устанавливаются scripts/setup-runtime.ps1.
WHISPER_MODEL=runtime/models/ggml-large-v3-turbo.bin
WHISPER_VAD_MODEL=runtime/models/ggml-silero-v6.2.0.bin
SILERO_MODEL=runtime/models/v5_5_ru.pt
SILERO_SPEAKER=aidar

# Новая дорожка: приглушённый stereo-оригинал + mono-голос по центру.
ORIGINAL_VOLUME=0.35
