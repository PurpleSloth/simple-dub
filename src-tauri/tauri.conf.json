{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simple Dub",
  "version": "0.1.1",
  "identifier": "io.github.purplesloth.simple-dub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run bundle:prepare && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simple Dub",
        "width": 1120,
        "height": 780,
        "minWidth": 720,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe",
      "bin/piper-worker"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
